#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# golden-path — pre-commit Inspector
#
# A self-contained, tracked quality gate. Activate ONCE per clone:
#     git config core.hooksPath .githooks
# Do NOT bypass with --no-verify. If it blocks you, fix the cause.
#
# Design notes (each one paid for in a real project):
#   * Every variable is quoted. A path with a space ("D:\My Project") would
#     otherwise word-split and the hook dies on `command not found`.
#   * Tools run via `npx --no-install` so they come from THIS project's
#     node_modules — deterministic, version-pinned, no global installs.
#   * Each tool is "run if present, else skip with a hint" — so this hook sits
#     happily on top of any project, half-scaffolded or complete.
#   * Type errors are a HARD gate (no `|| true`). A type error that only
#     "surfaces" is a type error that ships.
# ---------------------------------------------------------------------------
set -eu

echo "🔍 golden-path pre-commit gate..."

STAGED="$(git diff --cached --name-only --diff-filter=ACM)"
has_staged() { printf '%s\n' "$STAGED" | grep -qE "$1"; }
have()       { command -v "$1" >/dev/null 2>&1; }
npx_have()   { [ -d node_modules ] && npx --no-install "$1" --version >/dev/null 2>&1; }

FAIL=0

# 1. Lint — if ESLint is installed and JS/TS is staged.
if has_staged '\.(jsx?|tsx?|mjs|cjs)$'; then
  if npx_have eslint; then
    echo "  • lint"
    npx --no-install eslint . || { echo "❌ ESLint failed — try: npx eslint --fix ."; FAIL=1; }
  else
    echo "  • lint — skipped (eslint not installed yet)"
  fi
fi

# 2. Type-check — HARD gate when a tsconfig is present.
if [ -f tsconfig.json ] && npx_have tsc; then
  echo "  • type-check"
  npx --no-install tsc --noEmit || { echo "❌ Type-check failed — fix the type errors above."; FAIL=1; }
fi

# 3. Tests — the project's own (non-interactive) test script.
if [ -f package.json ] && grep -q '"test"' package.json && [ -d node_modules ]; then
  echo "  • tests"
  npm test --silent || { echo "❌ Tests failed."; FAIL=1; }
fi

[ "$FAIL" -ne 0 ] && { echo "❌ Inspector blocked the commit — fix the above, then re-commit."; exit 1; }

# 4. Secret scan — ALWAYS ON, BLOCKING. Built-in regex + gitleaks if present.
ADDED="$(git diff --cached --diff-filter=ACM -U0 | grep -E '^\+' | grep -vE '^\+\+\+' || true)"
HIGH="$(printf '%s\n' "$ADDED" | grep -inE \
  'AIza[0-9A-Za-z_-]{20,}|sk-[A-Za-z0-9]{20,}|ghp_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----|shp(at|ca|pa|ss)_[a-fA-F0-9]{32}' \
  || true)"
HEUR="$(printf '%s\n' "$ADDED" | grep -inE \
  "(password|passwd|secret|secret_key|api_key|apikey|access_token|auth_token|private_key|client_secret)[\"' ]*[:=][[:space:]]*[\"'][^\"' ]{8,}[\"']" \
  | grep -viE 'example|placeholder|change[_-]?me|your[_-]|dev-|test-|<[a-z_-]+>|process\.env|import\.meta\.env' || true)"
if [ -n "${HIGH}${HEUR}" ]; then
  echo "❌ Possible hardcoded secret — commit BLOCKED:"
  [ -n "$HIGH" ] && printf '%s\n' "$HIGH" | sed 's/^/    [key-format]    /'
  [ -n "$HEUR" ] && printf '%s\n' "$HEUR" | sed 's/^/    [sensitive-var] /'
  echo "   → Real secrets belong in a secret manager or a gitignored .env."
  echo "   → Read them via process.env / import.meta.env — never as literals."
  exit 1
fi
if have gitleaks; then
  echo "  • gitleaks"
  gitleaks protect --staged --no-banner || { echo "❌ gitleaks flagged staged changes."; exit 1; }
fi

echo "✅ All checks passed."
