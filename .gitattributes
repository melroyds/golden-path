# Normalise line endings. The repo stores LF; checkout converts per the rules below.
* text=auto eol=lf

# Shell scripts and the git hook MUST stay LF — they run under bash/sh, and a CRLF
# line ending breaks the shebang ("bad interpreter") on Windows Git Bash.
*.sh         text eol=lf
.githooks/** text eol=lf

# Windows-native scripts want CRLF.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binaries — never touch.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
